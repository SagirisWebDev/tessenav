# .distignore — paths excluded from the production zip.
# Used by `npm run plugin-zip` (sagiris-plugin-zip global script via rsync).

# Source (uncompiled). Only build/ ships.
/src

# Tests & test infrastructure.
/tests
/bin
/phpunit.xml.dist
/phpunit.xml
.phpunit.result.cache
jest.config.js
playwright.config.js
/test-results

# Internal docs (ADRs, QA fixtures, design notes) and agent context files.
/docs
CLAUDE.md
CONTEXT.md
/.swd-harness
/.claude

# Dev dependencies & lockfiles.
/node_modules
/vendor
package.json
package-lock.json
composer.json
composer.lock

# Tooling state.
/.git
/.github
.gitignore
.gitattributes
.distignore
.editorconfig
.eslintrc
.prettierrc
.babelrc
webpack.config.js

# Captured screenshots / playwright artifacts (not in git anyway).
/.playwright-mcp
*.png
*.jpg
*.jpeg

# Build & release zip artifacts (must not appear inside the release zip itself).
*.zip
/Sites

# OS junk.
.DS_Store
Thumbs.db
